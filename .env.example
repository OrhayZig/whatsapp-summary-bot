# Copy this file to ".env" for local testing and fill in your real values.
# On Render you set these same names in the dashboard (Environment tab) instead.

# Your Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model to use for summaries (default is fine)
CLAUDE_MODEL=claude-sonnet-4-6

# Port the server listens on (Render sets this automatically; 3000 for local)
PORT=3000
